# ==============================================================================
# SPARQ CONNECTION LAB - Environment Variables Template
# ==============================================================================
# Instructions:
# 1. Copy this file and rename it to `.env.local`
# 2. Fill in the values for the API keys matching your environment
# ==============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# 1. SUPABASE (Database, Auth, Storage)
# Get these project settings from your Supabase Dashboard
# ──────────────────────────────────────────────────────────────────────────────
# The URL of your Supabase project (e.g., https://xyzcompany.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url

# The public anon key for browser clients
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# The secret service role key (NEVER expose this to the browser!)
# Used for backend administrative tasks like Server-side Memory Management
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ──────────────────────────────────────────────────────────────────────────────
# 2. AI MODEL PROVIDERS (Peter AI, Context generation, Voice processing)
# ──────────────────────────────────────────────────────────────────────────────
# OpenAI API Key (Used for Whisper Voice Transcription & LLM Moderation Filters)
OPENAI_API_KEY=your_openai_api_key_here

# OpenRouter API Key (Used to route standard Peter AI Chat prompts to specific models)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ──────────────────────────────────────────────────────────────────────────────
# 3. MEMORY & EXTERNAL SERVICES
# ──────────────────────────────────────────────────────────────────────────────
# Supabase Vector DB will be used for long-term Peter memory (pgvector)
# No additional keys needed — uses SUPABASE_SERVICE_ROLE_KEY above
